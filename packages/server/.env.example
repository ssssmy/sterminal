# 服务配置
PORT=3001
# 监听地址：容器 / 远程访问必须 0.0.0.0；同机反代独占可设 127.0.0.1
HOST=0.0.0.0
NODE_ENV=development
BASE_URL=http://localhost:3001

# CORS：默认 '*' 开放所有前端 origin（自托管 + Electron 客户端友好，安全由 JWT 保证）
# 想锁定到指定 origin，逗号分隔列出，例：
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=*

# 数据库
DB_PATH=./data/sterminal.db

# JWT 密钥（生产环境请使用随机强密钥）
JWT_SECRET=dev-secret-please-change-in-production

# 邮件服务
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
MAIL_FROM=STerminal <no-reply@example.com>

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 文件上传目录
UPLOAD_DIR=./uploads

# 限流配置（每分钟最大请求数）
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_SYNC=30

# Docker 构建镜像源（可选，仅在国内 / 防火墙环境下需要）
# 不设置则走 Debian / npm 官方源
# 注意：APT_MIRROR 用 http:// — bookworm-slim 没有 ca-certificates，
#       Dockerfile 也会自动把 https:// 改成 http://；apt 包靠 GPG 签名验证完整性。
# APT_MIRROR=http://mirrors.aliyun.com
# NPM_REGISTRY=https://registry.npmmirror.com

# 生产部署（docker-compose.prod.yml）使用的镜像 tag。
# 不设则默认 latest；推荐线上锁定到具体版本号（如 0.1.2）避免意外升级。
# IMAGE_TAG=latest
