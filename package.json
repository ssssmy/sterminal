{
  "name": "sterminal",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform terminal management tool with SSH/SFTP client",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "client:dev": "npm run dev --workspace=packages/client",
    "client:build": "npm run build --workspace=packages/client",
    "server:dev": "npm run dev --workspace=packages/server",
    "server:build": "npm run build --workspace=packages/server"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
