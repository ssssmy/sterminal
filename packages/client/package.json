    "electron:build": "electron-builder",
    "pack:mac": "vue-tsc --noEmit && vite build && electron-builder --mac",
    "pack:win": "vue-tsc --noEmit && vite build && electron-builder --win",
    "pack:linux": "vue-tsc --noEmit && vite build && electron-builder --linux",
    "pack:all": "vue-tsc --noEmit && vite build && electron-builder --mac --win --linux",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@xterm/addon-fit": "^0.10.0",
