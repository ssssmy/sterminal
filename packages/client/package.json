    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.0.0",
    "canvas": "^3.2.2",
    "element-plus": "^2.9.0",
    "gif-encoder-2": "^1.0.5",
    "libsodium-wrappers-sumo": "^0.7.16",
    "node-pty": "^1.1.0",
    "pinia": "^2.2.0",
    "ssh2": "^1.16.0",
    "uuid": "^11.0.0",
    "vue": "^3.5.0",
    "vue-i18n": "^9.14.0",
