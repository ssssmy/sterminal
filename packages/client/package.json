    "@types/ssh2": "^1.15.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "sass": "^1.82.0",
    "typescript": "^5.7.0",
    "unplugin-auto-import": "^0.18.6",
    "unplugin-vue-components": "^0.27.5",
