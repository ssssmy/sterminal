{
  "name": "sterminal",
  "version": "0.1.3",
  "private": true,
  "description": "Cross-platform terminal management tool with SSH/SFTP client",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "client:dev": "npm run dev --workspace=packages/client",
    "client:build": "npm run build --workspace=packages/client",
    "server:dev": "npm run dev --workspace=packages/server",
    "server:build": "npm run build --workspace=packages/server",
    "client:pack:mac": "npm run pack:mac --workspace=packages/client",
    "client:pack:win": "npm run pack:win --workspace=packages/client",
    "client:pack:linux": "npm run pack:linux --workspace=packages/client",
    "client:pack:all": "npm run pack:all --workspace=packages/client"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
